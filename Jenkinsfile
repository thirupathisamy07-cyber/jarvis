pipeline {
    agent any

    stages {
        stage('Clone') {
            steps {
                echo 'Cloning successful!'
            }
        }

        stage('Build') {
            steps {
                echo 'Building Jarvis project...'
            }
        }

        stage('Run') {
            steps {
                echo 'Jarvis is running!'
            }
        }
    }
}
